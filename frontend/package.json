{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev",
    "dev:clean": "PORT=${PORT:-3000}; PID=$(lsof -nP -iTCP:$PORT -sTCP:LISTEN | awk 'NR==2{print $2}' || true); if [ -n \"$PID\" ]; then kill \"$PID\" || true; fi; rm -rf .next node_modules/.cache; WATCHPACK_POLLING=true next dev --port $PORT",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.182.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
